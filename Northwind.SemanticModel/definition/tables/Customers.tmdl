	partition Customers = m
		mode: import
		source =
				let
				    來源 = Sql.Database(".", "Northwind"),
				    dbo_Customers = 來源{[Schema="dbo",Item="Customers"]}[Data]
				in
				    dbo_Customers

	annotation PBI_ResultType = Table

