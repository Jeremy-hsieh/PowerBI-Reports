table Customers
	lineageTag: 087cc1cc-0b08-4049-8c7b-b481396763e0

	/// 購買超過1次的客戶数
	measure 回頭客數 =
			VAR CustomerOrders = SUMMARIZE('Orders', 'Orders'[CustomerID], "OrderCount", COUNTA('Orders'[OrderID]))
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('Orders'[CustomerID]),
			    FILTER(
			        CustomerOrders,
			        [OrderCount] > 1
			    )
			)
		formatString: #,##0
		lineageTag: 2e587714-ab0d-4ae6-817a-376ad8128457

	/// 有購买記錄的不同客戶总數
	measure 客戶總數 = DISTINCTCOUNT('Orders'[CustomerID])
		formatString: #,##0
		lineageTag: d7b64a8a-662a-4421-adbb-7d7fc0ce72bb

	/// 整体購买購次数 / 客戶数
	measure 平均購買次數 = DIVIDE(COUNTA('Orders'[OrderID]), [客戶總數], 0)
		formatString: 0.00
		lineageTag: bc2a3b99-fd61-43f2-b89e-ee9a7d6235a7

	/// 每位客戶的平均消費额
	measure 每位客戶平均消費額 = DIVIDE(SUMX('Order Details', 'Order Details'[Quantity] * 'Order Details'[UnitPrice]), [客戶總數], 0)
		formatString: #,##0.00
		lineageTag: 0028265d-e0ee-4cc6-a41d-07f0f9d9553b

	/// 只購买一次的客戶数量
	measure 一次性客戶數 = COUNTROWS(FILTER(SUMMARIZE('Orders', 'Orders'[CustomerID], "OrderCount", COUNTA('Orders'[OrderID])), [OrderCount] = 1))
		formatString: #,##0
		lineageTag: baf234b6-dbff-496f-a48e-3b1edb0850ca

	/// 客戶保留率 = 回头客戶数 / 客戶總数
	measure 客戶保留率 = DIVIDE(COUNTROWS(FILTER(SUMMARIZE('Orders', 'Orders'[CustomerID], "OrderCount", COUNTA('Orders'[OrderID])), [OrderCount] > 1)), DISTINCTCOUNT('Orders'[CustomerID]), 0)
		formatString: 0.00%
		lineageTag: eb38501a-640c-487c-be3e-12476c17401f

	/// 客戶流失率 = 一次性客戶数 / 客戶總数
	measure 客戶流失率 = DIVIDE(COUNTROWS(FILTER(SUMMARIZE('Orders', 'Orders'[CustomerID], "OrderCount", COUNTA('Orders'[OrderID])), [OrderCount] = 1)), DISTINCTCOUNT('Orders'[CustomerID]), 0)
		formatString: 0.00%
		lineageTag: b97f3cea-c43f-46fd-91d6-ab8ff3c27a24

